<Window x:Class="WardLock.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Password" Height="200" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1e1e2e" Foreground="#cdd6f4"
        WindowStyle="ToolWindow" ShowInTaskbar="False">

    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Text="Enter a password to encrypt your backup:"
                   FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"/>
        <PasswordBox x:Name="PasswordInput" FontSize="14" Padding="6,4"
                     Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                     CaretBrush="#cdd6f4" KeyDown="OnKeyDown"/>
        <StackPanel x:Name="ConfirmPanel" Margin="0,8,0,0">
            <TextBlock Text="Confirm password:" FontSize="12" Foreground="#a6adc8" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ConfirmInput" FontSize="14" Padding="6,4"
                         Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                         CaretBrush="#cdd6f4" KeyDown="OnKeyDown"/>
        </StackPanel>
        <TextBlock x:Name="ErrorText" Foreground="#f38ba8" FontSize="11" Margin="0,6,0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="12,6" Margin="0,0,8,0"
                    Background="#313244" Foreground="#cdd6f4" BorderThickness="0"
                    Click="OnCancel" Cursor="Hand"/>
            <Button Content="OK" Padding="12,6"
                    Background="#89b4fa" Foreground="#1e1e2e" FontWeight="SemiBold"
                    BorderThickness="0" Click="OnOk" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
